{
  "boot-source": {
    "kernel_image_path": "/opt/firecracker/kernel/vmlinux",
    "boot_args": "console=ttyS0 reboot=k panic=1 pci=off ip=172.16.0.6::172.16.0.5:255.255.255.252::eth0:off",
    "initrd_path": null
  },
  "drives": [
    {
      "drive_id": "rootfs",
      "path_on_host": "/opt/firecracker/images/rootfs.ext4",
      "is_root_device": true,
      "is_read_only": false,
      "cache_type": "Unsafe",
      "io_engine": "Sync"
    }
  ],
  "network-interfaces": [
    {
      "iface_id": "eth0",
      "host_dev_name": "fc-example",
      "guest_mac": "AA:FC:00:00:00:01"
    }
  ],
  "machine-config": {
    "vcpu_count": 2,
    "mem_size_mib": 256,
    "smt": false,
    "track_dirty_pages": false
  },
  "balloon": null,
  "vsock": null,
  "logger": null,
  "metrics": null,
  "entropy": null
}
