#!/bin/bash
# Lightweight init for Firecracker microVMs.
# Mounts essential filesystems, starts sshd + vsock relay,
# then drops to a login shell on the serial console.

# Mount essential filesystems
mount -t proc proc /proc 2>/dev/null
mount -t sysfs sysfs /sys 2>/dev/null
mkdir -p /dev/pts
mount -t devpts devpts /dev/pts -o gid=5,mode=620,ptmxmode=000 2>/dev/null
ln -sf pts/ptmx /dev/ptmx 2>/dev/null
mount -t tmpfs tmpfs /run 2>/dev/null
mkdir -p /run/sshd

# Set hostname
hostname -F /etc/hostname 2>/dev/null

# Bring up loopback
ip link set lo up 2>/dev/null

# Start SSH server
/usr/sbin/sshd

# Start vsock-to-SSH relay
/usr/local/bin/vsock-ssh-relay &

# Drop to a login shell on the serial console
exec /sbin/getty -L ttyS0 115200 vt100
