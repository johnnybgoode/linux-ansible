#!/usr/bin/env bash
set -euo pipefail

# Firecracker microVM lifecycle manager.
#
# Thin wrapper around firecracker that handles tap device setup/teardown
# and process management. VM configuration is defined entirely by the
# Firecracker JSON config file.
#
# Usage:
#   fc-vm build  --config <config.json> [--image alpine:latest] [--size 512]
#   fc-vm start  --config <config.json> --name <vm_name>
#   fc-vm stop   --name <vm_name>
#   fc-vm status [--name <vm_name>]
#
# Runtime state is stored in /opt/firecracker/vms/<name>/
# (pid file, api socket)

FC_BASE="/opt/firecracker"
FC_VMS_DIR="$FC_BASE/vms"
FC_SSH_KEY="$FC_BASE/ssh/fc_vm_key"
FC_SSH_PUBKEY="$FC_BASE/ssh/fc_vm_key.pub"
FC_CID_FILE="$FC_BASE/next_cid"

usage() {
  cat <<'EOF'
Usage:
  fc-vm build    --config <config.json> [--image IMAGE] [--size SIZE_MB]
  fc-vm start    --config <config.json> --name <vm_name> [--foreground]
  fc-vm stop     --name <vm_name>
  fc-vm connect  --name <vm_name>
  fc-vm status   [--name <vm_name>]

build:
  Reads the config to find drive paths and builds rootfs images from a
  Docker image. Downloads a guest kernel if kernel_image_path doesn't exist.
  Bakes SSH pubkey and vsock relay service into the rootfs.
    --config  Firecracker JSON config file
    --image   Docker image for rootfs (default: alpine:latest)
    --size    Rootfs size in MB (default: 512)

start:
  Creates tap devices, assigns a vsock CID, and launches firecracker.
    --config      Firecracker JSON config file
    --name        Unique name for this VM instance
    --foreground  Run in foreground with serial console (default: background)

stop:
  Gracefully shuts down the VM and tears down tap devices.
    --name    VM instance name

connect:
  Opens an SSH session to a running VM over vsock.
    --name    VM instance name

status:
  Shows running VMs and their state.
    --name    Filter to a specific VM (optional)

Examples:
  fc-vm build --config vms/web.json --image ubuntu:24.04 --size 1024
  fc-vm start --config vms/web.json --name project-a
  fc-vm connect --name project-a
  fc-vm stop --name project-a
  fc-vm status
EOF
  exit 1
}

need_jq() {
  if ! command -v jq &>/dev/null; then
    echo "Error: jq is required but not installed"
    exit 1
  fi
}

# Allocate or reuse a vsock CID for a VM
get_or_assign_cid() {
  local vm_dir="$1"
  if [[ -f "$vm_dir/cid" ]]; then
    cat "$vm_dir/cid"
    return
  fi
  local cid
  cid=$(cat "$FC_CID_FILE" 2>/dev/null || echo 3)
  echo "$cid" >"$vm_dir/cid"
  echo $(( cid + 1 )) >"$FC_CID_FILE"
  echo "$cid"
}

# --- build kernel URL ---
get_kernel_url() {
  ARCH="$(uname -m)"
  release_url="https://github.com/firecracker-microvm/firecracker/releases"
  latest_version=$(basename $(curl -fsSLI -o /dev/null -w %{url_effective} ${release_url}/latest))
  CI_VERSION=${latest_version%.*}
  latest_kernel_key=$(curl -fsSL "https://spec.ccfc.min.s3.amazonaws.com/?prefix=firecracker-ci/$CI_VERSION/$ARCH/vmlinux-&list-type=2" |
    grep -oP "(?<=<Key>)(firecracker-ci/$CI_VERSION/$ARCH/vmlinux-[0-9]+\.[0-9]+\.[0-9]{1,3})(?=</Key>)" |
    sort -V | tail -1)
  echo "https://s3.amazonaws.com/spec.ccfc.min/${latest_kernel_key}"
}

# --- build ---

cmd_build() {
  local config="" image="alpine:latest" size=512

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --config)
      config="$2"
      shift 2
      ;;
    --image)
      image="$2"
      shift 2
      ;;
    --size)
      size="$2"
      shift 2
      ;;
    -*)
      echo "Unknown option: $1"
      usage
      ;;
    *)
      echo "Unexpected argument: $1"
      usage
      ;;
    esac
  done

  [[ -z "$config" ]] && {
    echo "Error: --config is required"
    usage
  }
  [[ -f "$config" ]] || {
    echo "Error: config file not found: $config"
    exit 1
  }

  need_jq

  # Ensure guest kernel exists
  local kernel_path
  kernel_path=$(jq -r '.["boot-source"].kernel_image_path' "$config")
  if [[ ! -f "$kernel_path" ]]; then
    echo "Kernel not found at $kernel_path — downloading..."
    mkdir -p "$(dirname "$kernel_path")"
    curl -fsSL -o "$kernel_path" "$(get_kernel_url)"
    echo "Saved kernel to $kernel_path"
  fi

  # Build rootfs for each drive that doesn't exist yet
  local drive_count
  drive_count=$(jq '.drives | length' "$config")

  for ((i = 0; i < drive_count; i++)); do
    local path is_root
    path=$(jq -r ".drives[$i].path_on_host" "$config")
    is_root=$(jq -r ".drives[$i].is_root_device" "$config")

    if [[ -f "$path" ]]; then
      echo "Drive already exists: $path (skipping)"
      continue
    fi

    echo "Building drive: $path (${size}MB from $image)..."
    mkdir -p "$(dirname "$path")"

    dd if=/dev/zero of="$path" bs=1M count="$size" status=progress
    mkfs.ext4 -F "$path"

    if [[ "$is_root" == "true" ]]; then
      # Populate root drive from Docker image
      local mnt
      mnt=$(mktemp -d)
      local cid
      cid=$(docker create "$image")
      sudo mount "$path" "$mnt"
      docker export "$cid" | sudo tar -xf - -C "$mnt"
      docker rm "$cid" >/dev/null

      # Basic guest setup
      local drive_id
      drive_id=$(jq -r ".drives[$i].drive_id" "$config")
      echo "$drive_id" | sudo tee "$mnt/etc/hostname" >/dev/null
      echo "nameserver 1.1.1.1" | sudo tee "$mnt/etc/resolv.conf" >/dev/null

      # Ensure a working init exists
      if [[ ! -e "$mnt/sbin/init" ]] && [[ -e "$mnt/bin/busybox" ]]; then
        sudo ln -sf /bin/busybox "$mnt/sbin/init"
      fi

      # Set up getty on serial console for a proper TTY
      if [[ -d "$mnt/etc/init" ]]; then
        sudo tee "$mnt/etc/init/ttyS0.conf" >/dev/null <<'GETTY'
start on stopped rc or RUNLEVEL=[2345]
stop on RUNLEVEL=[!2345]
respawn
exec /sbin/getty -L ttyS0 115200 vt100
GETTY
      fi
      # Also add to inittab for sysvinit/busybox init
      if [[ -e "$mnt/etc/inittab" ]]; then
        echo 'ttyS0::respawn:/sbin/getty -L ttyS0 115200 vt100' | sudo tee -a "$mnt/etc/inittab" >/dev/null
      else
        echo 'ttyS0::respawn:/sbin/getty -L ttyS0 115200 vt100' | sudo tee "$mnt/etc/inittab" >/dev/null
      fi
      # Permit root login on ttyS0
      if [[ -e "$mnt/etc/securetty" ]]; then
        echo 'ttyS0' | sudo tee -a "$mnt/etc/securetty" >/dev/null
      fi

      # Bake SSH public key for vsock access
      if [[ -f "$FC_SSH_PUBKEY" ]]; then
        sudo mkdir -p "$mnt/root/.ssh"
        sudo chmod 700 "$mnt/root/.ssh"
        sudo cp "$FC_SSH_PUBKEY" "$mnt/root/.ssh/authorized_keys"
        sudo chmod 600 "$mnt/root/.ssh/authorized_keys"
        echo "Baked SSH public key into rootfs"
      else
        echo "Warning: SSH pubkey not found at $FC_SSH_PUBKEY — skipping"
        echo "  Run the Ansible playbook to generate it, or:"
        echo "  ssh-keygen -t ed25519 -f $FC_SSH_KEY -N '' -C fc-vm"
      fi

      # Install vsock-to-SSH relay (bridges vsock port 22 to sshd)
      # Uses python3 to avoid socat dependency in the guest
      sudo tee "$mnt/usr/local/bin/vsock-ssh-relay" >/dev/null <<'RELAY'
#!/usr/bin/env python3
"""Relay connections from vsock port 22 to localhost:22 (sshd)."""
import socket, os, select, sys, signal

VSOCK_PORT = 22
SSH_PORT = 22

def relay(client):
    """Bidirectional relay between vsock client and local sshd."""
    pid = os.fork()
    if pid:
        client.close()
        return
    # Child process handles this connection
    try:
        target = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        target.connect(("127.0.0.1", SSH_PORT))
        client.setblocking(False)
        target.setblocking(False)
        fds = [client, target]
        while True:
            r, _, _ = select.select(fds, [], [])
            for fd in r:
                data = fd.recv(65536)
                if not data:
                    raise ConnectionError
                dest = target if fd == client else client
                dest.sendall(data)
    except (ConnectionError, OSError):
        pass
    finally:
        client.close()
        target.close()
        os._exit(0)

signal.signal(signal.SIGCHLD, signal.SIG_IGN)
sock = socket.socket(socket.AF_VSOCK, socket.SOCK_STREAM)
sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
sock.bind((socket.VMADDR_CID_ANY, VSOCK_PORT))
sock.listen(8)
while True:
    client, _ = sock.accept()
    relay(client)
RELAY
      sudo chmod 755 "$mnt/usr/local/bin/vsock-ssh-relay"

      # Systemd service for the relay
      sudo mkdir -p "$mnt/etc/systemd/system/multi-user.target.wants"
      sudo tee "$mnt/etc/systemd/system/vsock-ssh-relay.service" >/dev/null <<'VSOCK'
[Unit]
Description=vsock to SSH relay
After=ssh.service sshd.service
Wants=ssh.service

[Service]
ExecStart=/usr/local/bin/vsock-ssh-relay
Restart=always
RestartSec=1

[Install]
WantedBy=multi-user.target
VSOCK
      sudo ln -sf ../vsock-ssh-relay.service \
        "$mnt/etc/systemd/system/multi-user.target.wants/vsock-ssh-relay.service"
      echo "Installed vsock-ssh-relay service"

      sudo umount "$mnt"
      rmdir "$mnt"
      echo "Populated root drive from $image"
    else
      echo "Created empty drive (mount in guest and use as needed)"
    fi
  done

  echo ""
  echo "Build complete. Start a VM with:"
  echo "  fc-vm start --config $config --name <vm_name>"
}

# --- start ---

cmd_start() {
  local config="" name="" foreground=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --config)
      config="$2"
      shift 2
      ;;
    --name)
      name="$2"
      shift 2
      ;;
    --foreground | -fg)
      foreground=true
      shift
      ;;
    -*)
      echo "Unknown option: $1"
      usage
      ;;
    *)
      echo "Unexpected argument: $1"
      usage
      ;;
    esac
  done

  [[ -z "$config" ]] && {
    echo "Error: --config is required"
    usage
  }
  [[ -z "$name" ]] && {
    echo "Error: --name is required"
    usage
  }
  [[ -f "$config" ]] || {
    echo "Error: config file not found: $config"
    exit 1
  }

  need_jq

  local vm_dir="$FC_VMS_DIR/$name"
  local socket="$vm_dir/firecracker.socket"
  local pidfile="$vm_dir/firecracker.pid"

  if [[ -f "$pidfile" ]] && kill -0 "$(cat "$pidfile")" 2>/dev/null; then
    echo "Error: VM '$name' is already running (PID $(cat "$pidfile"))"
    exit 1
  fi

  mkdir -p "$vm_dir"
  rm -f "$socket" "$vm_dir/v.sock"

  # Copy drives into vm_dir on first start, reuse on subsequent starts
  local runtime_config="$vm_dir/config.json"
  if [[ ! -f "$runtime_config" ]]; then
    echo "First start for '$name' — copying drives..."
    local drive_count
    drive_count=$(jq '.drives | length' "$config")

    # Start with the original config, then rewrite drive paths
    cp "$config" "$runtime_config"

    for ((i = 0; i < drive_count; i++)); do
      local src_path drive_id dest_path
      src_path=$(jq -r ".drives[$i].path_on_host" "$config")
      drive_id=$(jq -r ".drives[$i].drive_id" "$config")
      dest_path="$vm_dir/${drive_id}.ext4"

      if [[ ! -f "$src_path" ]]; then
        echo "Error: drive image not found: $src_path"
        rm -f "$runtime_config"
        exit 1
      fi

      cp "$src_path" "$dest_path"
      echo "  copied $src_path -> $dest_path"

      # Update the runtime config to point to the local copy
      local tmp
      tmp=$(jq ".drives[$i].path_on_host = \"$dest_path\"" "$runtime_config")
      echo "$tmp" > "$runtime_config"
    done
  else
    echo "Restarting '$name' with existing filesystem"
  fi

  # Assign vsock CID and inject into runtime config
  local cid vsock_path
  cid=$(get_or_assign_cid "$vm_dir")
  vsock_path="$vm_dir/v.sock"
  local tmp
  tmp=$(jq ".vsock = {\"guest_cid\": $cid, \"uds_path\": \"$vsock_path\"}" "$runtime_config")
  echo "$tmp" >"$runtime_config"

  # Set up tap devices for each network interface in the config
  local iface_count
  iface_count=$(jq '.["network-interfaces"] | length' "$config")
  local tap_names=()

  for ((i = 0; i < iface_count; i++)); do
    local tap_name
    tap_name=$(jq -r ".[\"network-interfaces\"][$i].host_dev_name" "$config")
    tap_names+=("$tap_name")

    if ip link show "$tap_name" &>/dev/null; then
      echo "Tap device $tap_name already exists, reusing"
      continue
    fi

    # Derive IP from guest MAC: use last octet for the /30 slot
    local mac guest_slot host_ip
    mac=$(jq -r ".[\"network-interfaces\"][$i].guest_mac // empty" "$config")
    if [[ -n "$mac" ]]; then
      # Last octet of MAC -> network slot
      guest_slot=$(printf '%d' "0x${mac##*:}")
    else
      guest_slot=$((i + 1))
    fi
    host_ip="172.16.0.$((guest_slot * 4 + 1))"

    sudo fc-tap-setup create "$tap_name" "$host_ip/30"
    echo "Created tap: $tap_name ($host_ip/30)"
  done

  # Save tap names for cleanup on stop
  printf '%s\n' "${tap_names[@]}" >"$vm_dir/tap_devices"

  echo ""
  echo "Starting VM '$name'..."
  echo "  config: $config"
  echo "  socket: $socket"
  echo "  vsock:  CID $cid ($vsock_path)"
  echo ""

  if [[ "$foreground" == "true" ]]; then
    echo "Running in foreground (serial console). Press Ctrl+C to stop."
    echo "---"
    # Trap to clean up tap devices on exit
    trap 'echo ""; echo "Cleaning up..."; rm -f "$pidfile" "$socket"; \
      if [[ -f "$vm_dir/tap_devices" ]]; then \
        while IFS= read -r t; do \
          ip link show "$t" &>/dev/null && sudo fc-tap-setup delete "$t"; \
        done < "$vm_dir/tap_devices"; \
        rm -f "$vm_dir/tap_devices"; \
      fi' EXIT
    echo "$$" >"$pidfile"
    exec firecracker \
      --api-sock "$socket" \
      --config-file "$runtime_config"
  else
    firecracker \
      --api-sock "$socket" \
      --config-file "$runtime_config" &
    local pid=$!
    echo "$pid" >"$pidfile"

    echo "VM '$name' started (PID $pid)"
    echo "Connect with: fc-vm connect --name $name"
    echo "Stop with:    fc-vm stop --name $name"
  fi
}

# --- stop ---

cmd_stop() {
  local name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --name)
      name="$2"
      shift 2
      ;;
    -*)
      echo "Unknown option: $1"
      usage
      ;;
    *)
      echo "Unexpected argument: $1"
      usage
      ;;
    esac
  done

  [[ -z "$name" ]] && {
    echo "Error: --name is required"
    usage
  }

  local vm_dir="$FC_VMS_DIR/$name"
  local pidfile="$vm_dir/firecracker.pid"
  local socket="$vm_dir/firecracker.socket"

  if [[ -f "$pidfile" ]]; then
    local pid
    pid=$(cat "$pidfile")
    if kill -0 "$pid" 2>/dev/null; then
      # Graceful shutdown via API
      if [[ -S "$socket" ]]; then
        curl -s --unix-socket "$socket" -X PUT \
          "http://localhost/actions" \
          -H "Content-Type: application/json" \
          -d '{"action_type": "SendCtrlAltDel"}' >/dev/null 2>&1 || true
        for i in {1..5}; do
          kill -0 "$pid" 2>/dev/null || break
          sleep 1
        done
      fi
      if kill -0 "$pid" 2>/dev/null; then
        kill "$pid"
        echo "Killed firecracker process $pid"
      else
        echo "VM shut down gracefully"
      fi
    fi
    rm -f "$pidfile"
  else
    echo "No PID file found for '$name'"
  fi

  rm -f "$socket" "$vm_dir/v.sock"

  # Tear down tap devices
  if [[ -f "$vm_dir/tap_devices" ]]; then
    while IFS= read -r tap_name; do
      if ip link show "$tap_name" &>/dev/null; then
        sudo fc-tap-setup delete "$tap_name"
      fi
    done <"$vm_dir/tap_devices"
    rm -f "$vm_dir/tap_devices"
  fi

  echo "VM '$name' stopped"
}

# --- connect ---

cmd_connect() {
  local name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --name)
      name="$2"
      shift 2
      ;;
    -*)
      echo "Unknown option: $1"
      usage
      ;;
    *)
      echo "Unexpected argument: $1"
      usage
      ;;
    esac
  done

  [[ -z "$name" ]] && {
    echo "Error: --name is required"
    usage
  }

  local vm_dir="$FC_VMS_DIR/$name"
  local vsock_path="$vm_dir/v.sock"
  local pidfile="$vm_dir/firecracker.pid"

  if [[ ! -f "$pidfile" ]] || ! kill -0 "$(cat "$pidfile")" 2>/dev/null; then
    echo "Error: VM '$name' is not running"
    exit 1
  fi

  if [[ ! -S "$vsock_path" ]]; then
    echo "Error: vsock socket not found at $vsock_path"
    exit 1
  fi

  if [[ ! -f "$FC_SSH_KEY" ]]; then
    echo "Error: SSH key not found at $FC_SSH_KEY"
    echo "Run the Ansible playbook or: ssh-keygen -t ed25519 -f $FC_SSH_KEY -N '' -C fc-vm"
    exit 1
  fi

  exec ssh \
    -o "ProxyCommand=fc-vsock-ssh $vsock_path 22" \
    -i "$FC_SSH_KEY" \
    -o StrictHostKeyChecking=no \
    -o UserKnownHostsFile=/dev/null \
    -o ServerAliveInterval=5 \
    -o ServerAliveCountMax=3 \
    root@localhost
}

# --- status ---

cmd_status() {
  local filter_name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
    --name)
      filter_name="$2"
      shift 2
      ;;
    -*)
      echo "Unknown option: $1"
      usage
      ;;
    *)
      echo "Unexpected argument: $1"
      usage
      ;;
    esac
  done

  if [[ ! -d "$FC_VMS_DIR" ]]; then
    echo "No VMs found"
    exit 0
  fi

  local found=false
  for vm_dir in "$FC_VMS_DIR"/*/; do
    [[ -d "$vm_dir" ]] || continue
    local name
    name=$(basename "$vm_dir")

    [[ -n "$filter_name" && "$name" != "$filter_name" ]] && continue
    found=true

    local status="stopped" pid="-"
    local pidfile="$vm_dir/firecracker.pid"

    if [[ -f "$pidfile" ]] && kill -0 "$(cat "$pidfile")" 2>/dev/null; then
      status="running"
      pid=$(cat "$pidfile")
    fi

    local taps="-" vm_cid="-"
    if [[ -f "$vm_dir/tap_devices" ]]; then
      taps=$(paste -sd, "$vm_dir/tap_devices")
    fi
    if [[ -f "$vm_dir/cid" ]]; then
      vm_cid=$(cat "$vm_dir/cid")
    fi

    printf "%-20s %-10s pid=%-8s cid=%-4s taps=%s\n" "$name" "$status" "$pid" "$vm_cid" "$taps"
  done

  if [[ "$found" == "false" ]]; then
    if [[ -n "$filter_name" ]]; then
      echo "VM '$filter_name' not found"
    else
      echo "No VMs found"
    fi
  fi
}

# --- main ---

[[ $# -lt 1 ]] && usage

cmd="$1"
shift

case "$cmd" in
build) cmd_build "$@" ;;
start) cmd_start "$@" ;;
stop) cmd_stop "$@" ;;
connect) cmd_connect "$@" ;;
status) cmd_status "$@" ;;
*) usage ;;
esac
